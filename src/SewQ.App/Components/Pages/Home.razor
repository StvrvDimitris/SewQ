@page "/"
@using Microsoft.Maui.ApplicationModel.DataTransfer
@using Microsoft.Maui.Storage
@inject IProjectService ProjectService
@inject ISettingsService SettingsService
@inject IBackupService BackupService
@inject ThemeState Theme
@inject ListState ListState
@inject NavigationManager Nav

<div class="screen">
    <div class="app-header">
        <div>
            <div class="app-logo">SewQ</div>
            <div class="app-sub">Sewing Projects</div>
        </div>
        <button class="icon-btn" @onclick="OpenSettings" aria-label="Settings">⚙</button>
    </div>

    <button class="btn-new" @onclick="OpenNewProject">+ New Project</button>

    <div class="filter-row">
        <button class="filter-chip @(ListState.Filter is null ? "active" : "")" @onclick="() => SetFilter(null)">
            All <span class="count">@_summaries.Count</span>
        </button>
        @foreach (var status in Enum.GetValues<ProjectStatus>())
        {
            var s = status;
            <button class="filter-chip @(ListState.Filter == s ? "active" : "")" @onclick="() => SetFilter(s)">
                @s.Label() <span class="count">@_summaries.Count(p => p.Status == s)</span>
            </button>
        }
    </div>

    <div class="project-list">
        @if (!Filtered.Any())
        {
            <div class="empty-note">No projects match this filter.</div>
        }
        @foreach (var project in Filtered)
        {
            var p = project;
            <div class="project-card" @onclick="() => OpenProject(p.Id)">
                <div class="project-card-top">
                    <div class="project-name">@p.Name</div>
                    <div class="status-badge @UiText.StatusCss(p.Status)">@p.Status.Label()</div>
                </div>
                <div class="cost-lines">
                    <div class="cost-line"><span>Materials</span><span>@p.MaterialsTotal.Money(_settings.Currency)</span></div>
                    <div class="cost-line"><span>Labour</span><span>@p.LabourTotal.Money(_settings.Currency)</span></div>
                </div>
                <div class="project-card-bottom">
                    <div class="total-amt">Total @p.TotalCost.Money(_settings.Currency)</div>
                    <div class="edited-label">Edited @UiText.Relative(p.UpdatedAt)</div>
                </div>
            </div>
        }
    </div>
</div>

<BottomSheet Open="_sheet != SheetKind.None" Title="@SheetTitle" Error="@_error" OnClose="CloseSheet" OnSave="SaveSheet">
    @if (_sheet == SheetKind.NewProject)
    {
        <div class="field">
            <label>Project name</label>
            <input class="form-control" @bind="_npName" placeholder="e.g. Blue Skirt" />
        </div>
        <div class="field">
            <label>Status</label>
            <select class="form-select" @bind="_npStatus">
                <option value="NotStarted">Not started</option>
                <option value="InProgress">In progress</option>
                <option value="Finished">Finished</option>
            </select>
        </div>
    }
    else if (_sheet == SheetKind.Settings)
    {
        <div class="field">
            <label>Theme</label>
            <div class="status-options">
                @foreach (var theme in Enum.GetValues<SewQTheme>())
                {
                    var t = theme;
                    <button class="status-option @(Theme.Theme == t ? "selected" : "")" @onclick="() => Theme.SetThemeAsync(t)">@t.Label()</button>
                }
            </div>
        </div>
        <div class="field">
            <div class="toggle-row">
                <div>
                    <label>Dark mode</label>
                    <div class="field-help">Switch to a darker, low-light palette</div>
                </div>
                <button class="toggle-switch @(Theme.DarkMode ? "on" : "")" @onclick="Theme.ToggleDarkModeAsync" aria-label="Toggle dark mode">
                    <span class="toggle-thumb"></span>
                </button>
            </div>
        </div>
        <div class="settings-divider"></div>
        <div class="field">
            <label>Default hourly rate</label>
            <input class="form-control" type="number" step="0.5" @bind="_rateText" placeholder="8.00" />
            <div class="field-help">Used as the starting rate for new Labour entries.</div>
        </div>
        <div class="field">
            <label>Currency</label>
            <select class="form-select" @bind="_currencyText">
                <option value="EUR">Euro (€)</option>
                <option value="USD">US Dollar ($)</option>
                <option value="GBP">British Pound (£)</option>
            </select>
        </div>
        <div class="settings-divider"></div>
        <div class="field">
            <label>Backup</label>
            <button class="add-link-btn" @onclick="ExportData">Export project data</button>
            <div class="field-help">Creates a downloadable backup of all your projects.</div>
            @if (_exported)
            {
                <div class="export-confirm">✓ Backup exported</div>
            }
        </div>
    }
</BottomSheet>

@code {
    private enum SheetKind { None, NewProject, Settings }

    private IReadOnlyList<ProjectSummaryDto> _summaries = [];
    private AppSettingsDto _settings = new(SewQTheme.Atelier, false, 8m, Currency.EUR);
    private SheetKind _sheet = SheetKind.None;
    private string? _error;

    private string _npName = "";
    private string _npStatus = "NotStarted";

    private string _rateText = "";
    private string _currencyText = "EUR";
    private bool _exported;

    private IEnumerable<ProjectSummaryDto> Filtered =>
        ListState.Filter is null ? _summaries : _summaries.Where(p => p.Status == ListState.Filter);

    private string SheetTitle => _sheet == SheetKind.Settings ? "Settings" : "Add Project";

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetAsync();
        _summaries = await ProjectService.GetProjectSummariesAsync();
    }

    private void SetFilter(ProjectStatus? status) => ListState.Filter = status;

    private void OpenProject(Guid id) => Nav.NavigateTo($"/project/{id}");

    private void OpenNewProject()
    {
        _npName = "";
        _npStatus = "NotStarted";
        _error = null;
        _sheet = SheetKind.NewProject;
    }

    private async Task OpenSettings()
    {
        _settings = await SettingsService.GetAsync();
        _rateText = _settings.DefaultHourlyRate.Compact();
        _currencyText = _settings.Currency.ToString();
        _exported = false;
        _error = null;
        _sheet = SheetKind.Settings;
    }

    private void CloseSheet() => _sheet = SheetKind.None;

    private async Task SaveSheet()
    {
        if (_sheet == SheetKind.NewProject)
        {
            if (string.IsNullOrWhiteSpace(_npName))
            {
                _error = "This field is required.";
                return;
            }
            var status = Enum.TryParse<ProjectStatus>(_npStatus, out var parsed) ? parsed : ProjectStatus.NotStarted;
            var id = await ProjectService.CreateProjectAsync(_npName, status);
            _sheet = SheetKind.None;
            Nav.NavigateTo($"/project/{id}");
            return;
        }

        if (_sheet == SheetKind.Settings)
        {
            var currency = Enum.TryParse<Currency>(_currencyText, out var parsedCurrency) ? parsedCurrency : Currency.EUR;
            _settings = _settings with
            {
                DefaultHourlyRate = UiText.ParseDecimal(_rateText),
                Currency = currency,
                Theme = Theme.Theme,
                DarkMode = Theme.DarkMode,
            };
            await SettingsService.SaveAsync(_settings);
            _sheet = SheetKind.None;
        }
    }

    private async Task ExportData()
    {
        var backup = await BackupService.CreateBackupAsync();
        var path = Path.Combine(FileSystem.CacheDirectory, backup.FileName);
        await File.WriteAllTextAsync(path, backup.Json);
        _exported = true;
        StateHasChanged();
        await Share.Default.RequestAsync(new ShareFileRequest
        {
            Title = "SewQ backup",
            File = new ShareFile(path),
        });
    }
}
