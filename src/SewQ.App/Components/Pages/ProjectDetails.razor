@page "/project/{Id:guid}"
@inject IProjectService ProjectService
@inject ISettingsService SettingsService
@inject NavigationManager Nav

<div class="screen">
    @if (_project is null)
    {
        <div class="details-header">
            <button class="back-btn" @onclick="GoBack" aria-label="Back">←</button>
            <div class="details-title">Project not found</div>
        </div>
    }
    else
    {
        <div class="details-header">
            <button class="back-btn" @onclick="GoBack" aria-label="Back">←</button>
            <div class="details-title">@_project.Name</div>
        </div>
        <div class="details-status-row">
            <button class="status-badge status-badge-btn @UiText.StatusCss(_project.Status)" @onclick="OpenStatusSheet">
                @_project.Status.Label() ▾
            </button>
        </div>

        <div class="summary-card">
            <div class="summary-label">Total cost</div>
            <div class="summary-total">@_project.TotalCost.Money(_currency)</div>
            <div class="summary-sub">
                <span>Materials @_project.MaterialsTotal.Money(_currency)</span>
                <span>Labour @_project.LabourTotal.Money(_currency)</span>
            </div>
        </div>

        <div class="quickadd-grid">
            <button class="quickadd-btn" @onclick="OpenAddMaterial">+ Material</button>
            <button class="quickadd-btn" @onclick="OpenAddLabour">+ Labour</button>
            <button class="quickadd-btn" @onclick="OpenAddMeasurement">+ Measurement</button>
            <button class="quickadd-btn" @onclick="OpenAddMachine">+ Machine</button>
        </div>

        <div class="section">
            <div class="section-head">
                <span class="section-title">Measurements</span>
            </div>
            @if (_project.Measurements.Count == 0)
            {
                <div class="empty-note">No measurements yet.</div>
            }
            <div class="item-list">
                @foreach (var measurement in _project.Measurements)
                {
                    var ms = measurement;
                    <div class="item-card">
                        <div class="item-top"><span>@ms.Name</span><span>@ms.Value @ms.Unit</span></div>
                        @if (!string.IsNullOrEmpty(ms.Notes))
                        {
                            <div class="item-meta">@ms.Notes</div>
                        }
                        <div class="item-actions">
                            <button class="item-action-btn" @onclick="() => OpenEditMeasurement(ms)">Edit</button>
                            <button class="item-action-btn danger" @onclick="() => DeleteMeasurement(ms.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            <button class="add-link-btn" @onclick="OpenAddMeasurement">+ Add measurement</button>
        </div>

        <div class="section">
            <div class="section-head">
                <span class="section-title">Materials</span>
                <span class="section-total">@_project.MaterialsTotal.Money(_currency)</span>
            </div>
            @if (_project.Materials.Count == 0)
            {
                <div class="empty-note">No materials yet.</div>
            }
            <div class="item-list">
                @foreach (var material in _project.Materials)
                {
                    var m = material;
                    <div class="item-card">
                        <div class="item-top"><span>@m.Name</span><span>@m.Cost.Money(_currency)</span></div>
                        @if (!string.IsNullOrEmpty(m.Notes))
                        {
                            <div class="item-meta">@m.Notes</div>
                        }
                        <div class="item-actions">
                            <button class="item-action-btn" @onclick="() => OpenEditMaterial(m)">Edit</button>
                            <button class="item-action-btn danger" @onclick="() => DeleteMaterial(m.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            <button class="add-link-btn" @onclick="OpenAddMaterial">+ Add material</button>
        </div>

        <div class="section">
            <div class="section-head">
                <span class="section-title">Labour</span>
                <span class="section-total">@_project.LabourTotal.Money(_currency)</span>
            </div>
            @if (_project.Labour.Count == 0)
            {
                <div class="empty-note">No labour logged yet.</div>
            }
            <div class="item-list">
                @foreach (var labour in _project.Labour)
                {
                    var l = labour;
                    <div class="item-card">
                        <div class="item-top"><span>@l.Task</span><span>@l.Cost.Money(_currency)</span></div>
                        <div class="item-meta">@(l.Hours.Compact())h × @l.Rate.Money(_currency)/h</div>
                        @if (!string.IsNullOrEmpty(l.Notes))
                        {
                            <div class="item-meta">@l.Notes</div>
                        }
                        <div class="item-actions">
                            <button class="item-action-btn" @onclick="() => OpenEditLabour(l)">Edit</button>
                            <button class="item-action-btn danger" @onclick="() => DeleteLabour(l.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            <button class="add-link-btn" @onclick="OpenAddLabour">+ Add labour</button>
        </div>

        <div class="section">
            <div class="section-head">
                <span class="section-title">Machine Settings</span>
            </div>
            @if (_project.MachineSettings.Count == 0)
            {
                <div class="empty-note">No machine settings yet.</div>
            }
            <div class="item-list">
                @foreach (var machineSetting in _project.MachineSettings)
                {
                    var mc = machineSetting;
                    <div class="item-card">
                        <div class="item-top"><span>@mc.Title</span><span>@mc.Fabric</span></div>
                        @if (!string.IsNullOrEmpty(mc.Notes))
                        {
                            <div class="machine-notes">@mc.Notes</div>
                        }
                        <div class="item-actions">
                            <button class="item-action-btn" @onclick="() => OpenEditMachine(mc)">Edit</button>
                            <button class="item-action-btn danger" @onclick="() => DeleteMachine(mc.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
            <button class="add-link-btn" @onclick="OpenAddMachine">+ Add machine setting</button>
        </div>
    }
</div>

<BottomSheet Open="_sheet != SheetKind.None" Title="@SheetTitle" Error="@_error" OnClose="CloseSheet" OnSave="SaveSheet">
    @if (_sheet == SheetKind.Material)
    {
        <div class="field">
            <label>Name</label>
            <input class="form-control" @bind="_fName" placeholder="e.g. Linen fabric" />
        </div>
        <div class="field">
            <label>Cost (@_currency.Symbol())</label>
            <input class="form-control" type="number" step="0.01" @bind="_fCost" placeholder="0.00" />
        </div>
        <div class="field">
            <label>Notes</label>
            <textarea class="form-control" rows="2" @bind="_fNotes" placeholder="Optional"></textarea>
        </div>
    }
    else if (_sheet == SheetKind.Labour)
    {
        <div class="field">
            <label>Task name</label>
            <input class="form-control" @bind="_fTask" placeholder="e.g. Sewing" />
        </div>
        <div class="two-col">
            <div class="field">
                <label>Hours</label>
                <input class="form-control" type="number" step="0.25" @bind="_fHours" @bind:event="oninput" placeholder="0" />
            </div>
            <div class="field">
                <label>Rate (@_currency.Symbol()/h)</label>
                <input class="form-control" type="number" step="0.5" @bind="_fRate" @bind:event="oninput" placeholder="8.00" />
            </div>
        </div>
        <div class="cost-preview">Cost: @LabourPreview</div>
        <div class="field">
            <label>Notes</label>
            <textarea class="form-control" rows="2" @bind="_fNotes" placeholder="Optional"></textarea>
        </div>
    }
    else if (_sheet == SheetKind.Measurement)
    {
        <div class="field">
            <label>Name</label>
            <input class="form-control" @bind="_fName" placeholder="e.g. Waist" />
        </div>
        <div class="two-col">
            <div class="field">
                <label>Value</label>
                <input class="form-control" @bind="_fValue" placeholder="72" />
            </div>
            <div class="field">
                <label>Unit</label>
                <input class="form-control" @bind="_fUnit" placeholder="cm" />
            </div>
        </div>
        <div class="field">
            <label>Notes</label>
            <textarea class="form-control" rows="2" @bind="_fNotes" placeholder="Optional"></textarea>
        </div>
    }
    else if (_sheet == SheetKind.Machine)
    {
        <div class="field">
            <label>Title</label>
            <input class="form-control" @bind="_fTitle" placeholder="e.g. Thin linen" />
        </div>
        <div class="field">
            <label>Fabric type</label>
            <input class="form-control" @bind="_fFabric" placeholder="e.g. Linen" />
        </div>
        <div class="field">
            <label>Notes</label>
            <textarea class="form-control" rows="5" @bind="_fNotes" placeholder="Straight stitch, length 2.5, tension 4..."></textarea>
        </div>
    }
    else if (_sheet == SheetKind.Status)
    {
        <div class="field">
            <label>Status</label>
            <div class="status-options">
                @foreach (var status in Enum.GetValues<ProjectStatus>())
                {
                    var s = status;
                    <button class="status-option @(_statusSel == s ? "selected" : "")" @onclick="() => _statusSel = s">@s.Label()</button>
                }
            </div>
        </div>
    }
</BottomSheet>

@code {
    private enum SheetKind { None, Material, Labour, Measurement, Machine, Status }

    [Parameter] public Guid Id { get; set; }

    private ProjectDetailsDto? _project;
    private Currency _currency = Currency.EUR;
    private decimal _defaultRate = 8m;

    private SheetKind _sheet = SheetKind.None;
    private Guid? _editingId;
    private string? _error;

    private string _fName = "", _fCost = "", _fNotes = "", _fTask = "", _fHours = "", _fRate = "";
    private string _fValue = "", _fUnit = "", _fTitle = "", _fFabric = "";
    private ProjectStatus _statusSel;

    private string LabourPreview =>
        (UiText.ParseDecimal(_fHours) * UiText.ParseDecimal(_fRate)).Money(_currency);

    private string SheetTitle => _sheet switch
    {
        SheetKind.Status => "Change Status",
        SheetKind.Material => _editingId is null ? "Add Material" : "Edit Material",
        SheetKind.Labour => _editingId is null ? "Add Labour" : "Edit Labour",
        SheetKind.Measurement => _editingId is null ? "Add Measurement" : "Edit Measurement",
        SheetKind.Machine => _editingId is null ? "Add Machine Setting" : "Edit Machine Setting",
        _ => "",
    };

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsService.GetAsync();
        _currency = settings.Currency;
        _defaultRate = settings.DefaultHourlyRate;
        await ReloadAsync();
    }

    private async Task ReloadAsync() => _project = await ProjectService.GetProjectAsync(Id);

    private void GoBack() => Nav.NavigateTo("/");

    private void ResetFields()
    {
        _fName = _fCost = _fNotes = _fTask = _fHours = _fRate = _fValue = _fTitle = _fFabric = "";
        _fUnit = "cm";
        _editingId = null;
        _error = null;
    }

    private void OpenAddMaterial()
    {
        ResetFields();
        _sheet = SheetKind.Material;
    }

    private void OpenEditMaterial(MaterialDto m)
    {
        ResetFields();
        _editingId = m.Id;
        _fName = m.Name;
        _fCost = m.Cost.Compact();
        _fNotes = m.Notes;
        _sheet = SheetKind.Material;
    }

    private void OpenAddLabour()
    {
        ResetFields();
        _fRate = _defaultRate.Compact();
        _sheet = SheetKind.Labour;
    }

    private void OpenEditLabour(LabourDto l)
    {
        ResetFields();
        _editingId = l.Id;
        _fTask = l.Task;
        _fHours = l.Hours.Compact();
        _fRate = l.Rate.Compact();
        _fNotes = l.Notes;
        _sheet = SheetKind.Labour;
    }

    private void OpenAddMeasurement()
    {
        ResetFields();
        _sheet = SheetKind.Measurement;
    }

    private void OpenEditMeasurement(MeasurementDto ms)
    {
        ResetFields();
        _editingId = ms.Id;
        _fName = ms.Name;
        _fValue = ms.Value;
        _fUnit = ms.Unit;
        _fNotes = ms.Notes;
        _sheet = SheetKind.Measurement;
    }

    private void OpenAddMachine()
    {
        ResetFields();
        _sheet = SheetKind.Machine;
    }

    private void OpenEditMachine(MachineSettingDto mc)
    {
        ResetFields();
        _editingId = mc.Id;
        _fTitle = mc.Title;
        _fFabric = mc.Fabric;
        _fNotes = mc.Notes;
        _sheet = SheetKind.Machine;
    }

    private void OpenStatusSheet()
    {
        if (_project is null)
            return;
        _error = null;
        _statusSel = _project.Status;
        _sheet = SheetKind.Status;
    }

    private void CloseSheet() => _sheet = SheetKind.None;

    private async Task SaveSheet()
    {
        if (_project is null)
            return;

        switch (_sheet)
        {
            case SheetKind.Material:
                if (Required(_fName))
                    return;
                var materialInput = new MaterialInput(_fName, UiText.ParseDecimal(_fCost), _fNotes);
                if (_editingId is Guid materialId)
                    await ProjectService.UpdateMaterialAsync(Id, materialId, materialInput);
                else
                    await ProjectService.AddMaterialAsync(Id, materialInput);
                break;

            case SheetKind.Labour:
                if (Required(_fTask))
                    return;
                var labourInput = new LabourInput(_fTask, UiText.ParseDecimal(_fHours), UiText.ParseDecimal(_fRate), _fNotes);
                if (_editingId is Guid labourId)
                    await ProjectService.UpdateLabourAsync(Id, labourId, labourInput);
                else
                    await ProjectService.AddLabourAsync(Id, labourInput);
                break;

            case SheetKind.Measurement:
                if (Required(_fName))
                    return;
                var measurementInput = new MeasurementInput(_fName, _fValue, string.IsNullOrWhiteSpace(_fUnit) ? "cm" : _fUnit, _fNotes);
                if (_editingId is Guid measurementId)
                    await ProjectService.UpdateMeasurementAsync(Id, measurementId, measurementInput);
                else
                    await ProjectService.AddMeasurementAsync(Id, measurementInput);
                break;

            case SheetKind.Machine:
                if (Required(_fTitle))
                    return;
                var machineInput = new MachineSettingInput(_fTitle, _fFabric, _fNotes);
                if (_editingId is Guid machineId)
                    await ProjectService.UpdateMachineSettingAsync(Id, machineId, machineInput);
                else
                    await ProjectService.AddMachineSettingAsync(Id, machineInput);
                break;

            case SheetKind.Status:
                await ProjectService.SetStatusAsync(Id, _statusSel);
                break;

            default:
                return;
        }

        _sheet = SheetKind.None;
        await ReloadAsync();
    }

    private bool Required(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            _error = "This field is required.";
            return true;
        }
        return false;
    }

    private async Task DeleteMaterial(Guid id)
    {
        await ProjectService.DeleteMaterialAsync(Id, id);
        await ReloadAsync();
    }

    private async Task DeleteLabour(Guid id)
    {
        await ProjectService.DeleteLabourAsync(Id, id);
        await ReloadAsync();
    }

    private async Task DeleteMeasurement(Guid id)
    {
        await ProjectService.DeleteMeasurementAsync(Id, id);
        await ReloadAsync();
    }

    private async Task DeleteMachine(Guid id)
    {
        await ProjectService.DeleteMachineSettingAsync(Id, id);
        await ReloadAsync();
    }
}
